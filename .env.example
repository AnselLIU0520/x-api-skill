# X API 凭证
# 从X开发者后台获取以下凭证
X_BEARER_TOKEN=your_bearer_token_here
X_CONSUMER_KEY=your_consumer_key_here
X_CONSUMER_SECRET=your_consumer_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here
X_USER_ID=your_user_id_here

# 代理设置（可选，如果需要通过代理访问）
# HTTPS_PROXY=http://127.0.0.1:17890

# 飞书Webhook（可选，用于推送日报）
# FEISHU_WEBHOOK=https://www.feishu.cn/flow/api/trigger-webhook/your_webhook_id

# 运营配置（可选）
# 执行间隔（毫秒），避免频率限制
OPERATION_DELAY=2000
# 最大重试次数
MAX_RETRIES=3
# 是否启用详细日志
VERBOSE_LOGGING=true

# 注意：
# 1. 不要提交包含真实凭证的.env文件到版本控制
# 2. 复制此文件为.env并填入真实凭证
# 3. 确保应用权限为"Read and Write"
# 4. 定期检查凭证有效期